{
    "name": "gitoonga/native-php-camera",
    "description": "NativePHP Mobile camera plugin — WebView bridge with Kotlin Android support for camera access and permissions.",
    "type": "nativephp-plugin",
    "version": "1.0.0",
    "license": "MIT",
    "keywords": ["camera", "webview", "permissions", "native", "android", "getUserMedia","nativephp", "mobile", "plugin", "laravel"],
    "authors": [
        {
            "name": "gitoonga",
            "email": "mjulius05@gmail.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "illuminate/support": "^10.0 || ^11.0 || ^12.0 || ^13.0",
        "nativephp/mobile": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0 || ^11.0",
        "orchestra/testbench": "^8.0 ||^ 9.0 || ^10.0 || ^11.0"
    },
    "autoload": {
        "psr-4": {
            "CameraPlugin\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CameraPlugin\\Tests\\": "tests/"
        }
    },
    "extra": {
        "camera-plugin": {
            "resources": "resources/"
        },
        "nativephp": {
            "manifest": "nativephp.json"
        },
        "laravel": {
            "providers": [
                "CameraPlugin\\CameraPluginServiceProvider"
            ],
            "aliases": {
                "CameraPlugin": "CameraPlugin\\Facades\\CameraPlugin"
            }
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-coverage": "vendor/bin/phpunit --coverage-text"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
